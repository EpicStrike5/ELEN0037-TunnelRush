library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

-- ================================================================
-- tunnel.vhd  —  Consolidated octagon tunnel renderer
-- ================================================================
-- Replaces: coord_transform, tunnel_core, tunnel_background,
--           colour_palette, tunnel_renderer, stage_manager.
--
-- PIPELINE (2 clock stages, same latency as old split design):
--   Stage 0 (register): rotate pixel into tunnel frame + ship hit
--   Combinational:      octagon classify, ring/spoke flags, depth
--   Stage 1 (register): colour priority mux → red/green/blue out
--
-- GEOMETRY:
--   Vanishing point at screen centre (400, 300) for 800×600.
--   Full 800×600 canvas — no black bars on the sides.
--   Vertical aspect correction: ady_corrected = ady × 21/16
--     This makes the outer octagon fit both screen edges at once,
--     and produces the "parabolic" look (top face fades faster).
--     Derived from Operius spoke measurements — bottom spokes
--     match within ~3°, side spokes within ~10° (blur uncertainty).
--   Dead zone radius ≈ 17 px from vanishing point (measured from
--     inner fading-zone coordinates in the Operius reference).
--
-- COLOUR (edit the KF_* arrays to change the tunnel's look):
--   hue_cnt cycles through 4 keyframe colours (~3.6 s per cycle).
--   Fixed colours for ship / obstacles / scoring rings below.
-- ================================================================

entity tunnel is
    port (
        clk_50            : in  std_logic;
        video_on          : in  std_logic;
        hpos              : in  std_logic_vector(9 downto 0);  -- screen column 0..799
        vpos              : in  std_logic_vector(9 downto 0);  -- screen row    0..599
        -- Tunnel rotation (from trig_rom, range ±255 ≈ ±1.0)
        cos_t             : in  signed(8 downto 0);
        sin_t             : in  signed(8 downto 0);
        -- Scroll counter — incremented once per frame by top level
        scroll            : in  std_logic_vector(7 downto 0);
        -- Colour cycle counter — incremented once per frame
        hue_cnt           : in  unsigned(9 downto 0);
        -- Ship sprite screen position
        ship_x            : in  unsigned(9 downto 0);
        ship_y            : in  unsigned(9 downto 0);
        -- Game state: "00"=IDLE  "01"=PLAYING  "10"=GAME_OVER
        game_state        : in  std_logic_vector(1 downto 0);
        -- Obstacles: 4 slots (from obstacle_manager)
        obs0_depth        : in  std_logic_vector(7 downto 0);
        obs0_face_sector  : in  std_logic_vector(2 downto 0);
        obs0_active       : in  std_logic;
        obs1_depth        : in  std_logic_vector(7 downto 0);
        obs1_face_sector  : in  std_logic_vector(2 downto 0);
        obs1_active       : in  std_logic;
        obs2_depth        : in  std_logic_vector(7 downto 0);
        obs2_face_sector  : in  std_logic_vector(2 downto 0);
        obs2_active       : in  std_logic;
        obs3_depth        : in  std_logic_vector(7 downto 0);
        obs3_face_sector  : in  std_logic_vector(2 downto 0);
        obs3_active       : in  std_logic;
        -- Scoring rings: 2 slots, appear on any face
        ring0_depth       : in  std_logic_vector(7 downto 0);
        ring0_active      : in  std_logic;
        ring1_depth       : in  std_logic_vector(7 downto 0);
        ring1_active      : in  std_logic;
        -- RGB output — arrives 2 clock cycles after hpos/vpos
        red               : out std_logic_vector(3 downto 0);
        green             : out std_logic_vector(3 downto 0);
        blue              : out std_logic_vector(3 downto 0)
    );
end tunnel;

architecture rtl of tunnel is

    -- ================================================================
    -- TUNING CONSTANTS  (change these to adjust the visual look)
    -- ================================================================

    -- Geometry
    constant DEAD_ZONE_RADIUS_SQ  : integer := 289;
        -- Square of the fading-zone radius in screen pixels.
        -- 17² = 289.  Pixels closer than 17 px to the vanishing point
        -- are drawn black (the "hole" at the tunnel centre).
        -- INCREASE to make the black hole bigger.
    constant OCT_DIAG_WEIGHT_Q8   : integer := 181;
        -- Diagonal projection factor in Q8 fixed-point (181/256).
        -- 181/256 ≈ 1/sqrt(2), giving near-equal 45° face sectors.
    constant OCT_DIAG_WEIGHT_SHIFT: integer := 8;
        -- Number of fractional bits in OCT_DIAG_WEIGHT_Q8.

    -- Rings (the concentric circles flying toward you)
    constant RING_SPACING_LOG2    : integer := 7;
        -- Rings are spaced 2^7 = 128 log-depth steps apart.
        -- DECREASE (e.g. 6) for denser rings.  INCREASE for sparser.
    constant RING_LINE_WIDTH      : integer := 1;
        -- Ring line thickness in log-depth steps (1 ≈ 1-2 px at edge).
        -- INCREASE for fatter rings.

    -- Spokes (the lines radiating from the vanishing point)
    constant SPOKE_MAX_WIDTH_PX   : integer := 3;
        -- Maximum spoke half-width in pixels (capped at screen edge).
        -- INCREASE for fatter spokes.
    constant SPOKE_TAPER_FACTOR   : integer := 32;
        -- Controls how fast spokes narrow toward the centre.
        -- Spoke fires when: spoke_dist × SPOKE_TAPER_FACTOR < oct_dist
        -- DECREASE for wider spokes near centre.  INCREASE for sharper.

    -- Depth shading (brightness of tunnel lines by depth)
    constant BRIGHTNESS_FLOOR     : integer := 4;
        -- Minimum brightness for the innermost rings (0=black, 15=full).
        -- INCREASE for a brighter, flatter look.
        -- DECREASE for darker inner rings (more depth effect).

    -- Obstacle / scoring ring depth band
    constant OBSTACLE_BAND_WIDTH  : integer := 6;
        -- Half-width (in depth_band units) of obstacle/ring blocks.
        -- INCREASE for thicker obstacle blocks.

    -- Ship sprite
    constant SHIP_DIAMOND_SIZE    : integer := 10;
        -- Manhattan radius of the ship's diamond sprite in pixels.
        -- INCREASE for a bigger ship.

    -- ================================================================
    -- COLOUR PALETTE  (edit here to change the game's look)
    -- ================================================================
    -- Tunnel lines cycle through 4 keyframe colours.
    -- hue_cnt[9:8] selects which pair (0-3), hue_cnt[7:4] blends within
    -- the pair.  Full cycle ≈ 3.6 s at 72 Hz.
    -- Entry [4] is a copy of [0] so the last → first transition is smooth.
    --
    -- Default "Operius vaporwave":
    --   0: neon pink    1: magenta    2: violet-blue    3: cyan
    type palette_array is array(0 to 4) of integer range 0 to 15;
    --                                  0     1     2     3   (4=0)
    constant KF_RED   : palette_array := (15,   15,    4,    0,   15);
    constant KF_GREEN : palette_array := ( 2,    0,    0,   12,    2);
    constant KF_BLUE  : palette_array := (12,   15,   15,   15,   12);

    -- Fixed colours for game objects (R, G, B each 0-15)
    constant SHIP_RED_VAL    : integer := 15;  -- ship: bright yellow
    constant SHIP_GREEN_VAL  : integer := 14;
    constant SHIP_BLUE_VAL   : integer :=  0;

    constant OBS_RED_VAL     : integer := 15;  -- obstacle: orange-red
    constant OBS_GREEN_VAL   : integer :=  4;
    constant OBS_BLUE_VAL    : integer :=  0;

    constant SCORE_RING_RED_VAL   : integer := 15;  -- scoring ring: gold
    constant SCORE_RING_GREEN_VAL : integer := 12;
    constant SCORE_RING_BLUE_VAL  : integer :=  0;

    -- ================================================================
    -- STAGE-0 PIPELINE REGISTERS
    -- Values computed from hpos/vpos, registered on the rising edge.
    -- The next stage (combinational classify) reads these.
    -- ================================================================

    -- Rotated pixel coordinates (tunnel frame, centred on vanishing point)
    signal dx_rotated    : signed(11 downto 0) := (others => '0');
    signal dy_rotated    : signed(11 downto 0) := (others => '0');

    -- Video blanking flag (video_on passed through 1 stage)
    signal video_active  : std_logic := '0';

    -- Whether the current pixel is inside the ship diamond sprite
    signal ship_hit      : std_logic := '0';

    -- Obstacle and ring signals delayed 1 cycle to match dx/dy_rotated
    signal obs0_depth_d, obs1_depth_d,
           obs2_depth_d, obs3_depth_d  : std_logic_vector(7 downto 0)
                                         := (others => '0');
    signal obs0_face_d,  obs1_face_d,
           obs2_face_d,  obs3_face_d   : std_logic_vector(2 downto 0)
                                         := (others => '0');
    signal obs0_active_d, obs1_active_d,
           obs2_active_d, obs3_active_d : std_logic := '0';

    signal ring0_depth_d, ring1_depth_d : std_logic_vector(7 downto 0)
                                          := (others => '0');
    signal ring0_active_d, ring1_active_d : std_logic := '0';

    -- ================================================================
    -- INTERMEDIATE SIGNALS FOR ABS() CHAIN
    -- VHDL-93 does not allow slicing a function result directly.
    -- Each abs() must go through an intermediate signal before slicing.
    -- ================================================================
    signal dx_11bit      : signed(10 downto 0);   -- lower 11 bits of dx_rotated
    signal dy_11bit      : signed(10 downto 0);
    signal dx_abs_signed : signed(10 downto 0);   -- abs(dx_11bit)  [still signed type]
    signal dy_abs_signed : signed(10 downto 0);
    signal pix_adx       : unsigned(9 downto 0);  -- |dx| as unsigned pixels
    signal pix_ady       : unsigned(9 downto 0);  -- |dy| as unsigned pixels
    signal pix_ady_eff   : unsigned(10 downto 0); -- |dy| × 21/16  (aspect correction)

    -- ================================================================
    -- COMBINATIONAL CLASSIFY SIGNALS
    -- Derived from dx/dy_rotated each clock, used by Stage-1 register.
    -- ================================================================

    -- Octagon distance metric in the aspect-corrected space.
    -- Think of it as the "radius" of the octagon that just reaches
    -- the current pixel.  0 at VP, ~400-600 at screen edges.
    signal oct_dist       : unsigned(9 downto 0);

    -- Which of the 8 octagon faces this pixel belongs to.
    -- Matches the encoding used by obstacle_manager:
    --   0=right(0°)  1=lower-right(45°)  2=bottom(90°)  3=lower-left(135°)
    --   4=left(180°) 5=upper-left(225°)  6=top(270°)    7=upper-right(315°)
    signal face_sector    : std_logic_vector(2 downto 0);

    -- Distance of this pixel from the nearest spoke line (lower = closer)
    signal spoke_dist     : unsigned(11 downto 0);

    -- 12-bit logarithm of oct_dist: [11:8]=octave, [7:0]=fractional
    -- Used for evenly-spaced rings and obstacle depth matching.
    signal log_depth      : unsigned(11 downto 0);

    -- Top 8 bits of log_depth — used to compare against obstacle depths
    signal depth_band     : unsigned(7 downto 0);

    -- Scroll-shifted log_depth; wraps to create the animated ring effect
    signal ring_phase     : unsigned(11 downto 0);

    -- Brightness multiplier (0=darkest, 15=full bright) based on oct_dist.
    -- Inner pixels are dimmer; outer pixels are brighter.
    signal brightness     : unsigned(3 downto 0);

    -- Classification flags (true/false for this pixel)
    signal on_ring        : std_logic;  -- pixel is on a ring line
    signal on_spoke       : std_logic;  -- pixel is on a spoke line
    signal in_dead_zone   : std_logic;  -- pixel is inside the VP fading hole
    signal on_obstacle    : std_logic;  -- pixel overlaps an active obstacle
    signal on_score_ring  : std_logic;  -- pixel overlaps a scoring ring

begin

    -- ================================================================
    -- ABS() CHAIN  (VHDL-93 compatible step-by-step)
    -- ================================================================
    dx_11bit      <= dx_rotated(10 downto 0);
    dy_11bit      <= dy_rotated(10 downto 0);
    dx_abs_signed <= abs(dx_11bit);
    dy_abs_signed <= abs(dy_11bit);
    pix_adx       <= unsigned(dx_abs_signed(9 downto 0));
    pix_ady       <= unsigned(dy_abs_signed(9 downto 0));

    -- Aspect correction: ady_corrected = ady + ady/4 + ady/16 = ady × 21/16
    -- This stretches the vertical axis so the octagon fits 800×600.
    pix_ady_eff   <= resize(pix_ady, 11)
                   + resize(shift_right(pix_ady, 2), 11)   -- ady / 4
                   + resize(shift_right(pix_ady, 4), 11);  -- ady / 16

    -- ================================================================
    -- DEAD ZONE CHECK
    -- Pixels within ~17 px of the vanishing point are flagged as dead.
    -- Uses true Euclidean distance squared (no sqrt needed for compare).
    -- ================================================================
    process(pix_adx, pix_ady)
        variable dist_sq : unsigned(19 downto 0);
    begin
        dist_sq := (pix_adx * pix_adx) + (pix_ady * pix_ady);
        if dist_sq < DEAD_ZONE_RADIUS_SQ then
            in_dead_zone <= '1';
        else
            in_dead_zone <= '0';
        end if;
    end process;

    -- ================================================================
    -- OCTAGON METRIC  (N=8, fixed)
    -- ------------------------------------------------------------------
    -- Computes oct_dist: the "octagonal radius" in aspect-corrected space.
    -- Three regions based on which face normal dominates:
    --
    --   Axial-X  (right / left face):   oct_dist = pix_adx
    --     when: pix_adx >= pix_ady_eff  AND  pix_adx >= oct_sum × 181/256
    --
    --   Axial-Y  (top / bottom face):   oct_dist = pix_ady_eff
    --     when: pix_ady_eff >= pix_adx  AND  pix_ady_eff >= oct_sum × 181/256
    --
    --   Diagonal (45° faces):           oct_dist = oct_sum × 181/256
    --     otherwise
    --
    -- Also sets face_sector (which of the 8 faces owns this pixel).
    -- ================================================================
    process(pix_adx, pix_ady_eff, dx_11bit, dy_11bit)
        variable adx_11          : unsigned(10 downto 0);
        variable oct_sum         : unsigned(10 downto 0);  -- adx + ady_eff
        variable oct_diag_scaled : unsigned(18 downto 0);  -- oct_sum × 181
        variable oct_diag_shifted: unsigned(18 downto 0);  -- (oct_sum × 181) >> 8
        variable oct_diag_dist   : unsigned(10 downto 0);  -- oct_sum × 181/256
        variable oct_axial       : unsigned(10 downto 0);  -- max(adx, ady_eff)
    begin
        adx_11        := resize(pix_adx, 11);
        oct_sum       := adx_11 + pix_ady_eff;
        -- × 181/256 via shift-and-add (181 = 128 + 32 + 16 + 4 + 1)
        oct_diag_scaled :=
              shift_left(resize(oct_sum, 19), 7)
            + shift_left(resize(oct_sum, 19), 5)
            + shift_left(resize(oct_sum, 19), 4)
            + shift_left(resize(oct_sum, 19), 2)
            + resize(oct_sum, 19);
        oct_diag_shifted := shift_right(oct_diag_scaled, OCT_DIAG_WEIGHT_SHIFT);
        oct_diag_dist    := oct_diag_shifted(10 downto 0);

        if adx_11 >= pix_ady_eff then
            oct_axial := adx_11;
        else
            oct_axial := pix_ady_eff;
        end if;

        if oct_diag_dist >= oct_axial then
            -- Diagonal face — which quadrant determines which diagonal
            oct_dist <= oct_diag_dist(9 downto 0);
            if    dx_11bit(10) = '0' and dy_11bit(10) = '0' then
                face_sector <= "001";  -- lower-right  (45°)
            elsif dx_11bit(10) = '1' and dy_11bit(10) = '0' then
                face_sector <= "011";  -- lower-left  (135°)
            elsif dx_11bit(10) = '1' and dy_11bit(10) = '1' then
                face_sector <= "101";  -- upper-left  (225°)
            else
                face_sector <= "111";  -- upper-right (315°)
            end if;
        else
            -- Axial face — which axis dominates?
            oct_dist <= oct_axial(9 downto 0);
            if adx_11 >= pix_ady_eff then
                -- Horizontal axis dominates
                if dx_11bit(10) = '0' then
                    face_sector <= "000";  -- right  (0°)
                else
                    face_sector <= "100";  -- left  (180°)
                end if;
            else
                -- Vertical axis dominates
                if dy_11bit(10) = '0' then
                    face_sector <= "010";  -- bottom  (90°)
                else
                    face_sector <= "110";  -- top    (270°)
                end if;
            end if;
        end if;
    end process;

    -- ================================================================
    -- SPOKE DETECTION
    -- ------------------------------------------------------------------
    -- Each spoke lies at the boundary between two adjacent faces.
    -- Reuse the same diagonal projection as oct_dist:
    --   diag_proj = (pix_adx + pix_ady_eff) × 181/256  ≈ (x+y)/sqrt(2)
    --
    -- Boundaries:
    --   right/left ↔ diagonal:  pix_adx     = diag_proj
    --   top/bottom ↔ diagonal:  pix_ady_eff = diag_proj
    --
    -- spoke_dist = minimum distance to those two boundaries.
    -- ================================================================
    process(pix_adx, pix_ady_eff)
        variable adx_12bit          : unsigned(11 downto 0);
        variable ady_eff_12bit      : unsigned(11 downto 0);
        variable oct_sum_12bit      : unsigned(11 downto 0);
        variable oct_diag_scaled    : unsigned(18 downto 0);
        variable oct_diag_shifted   : unsigned(18 downto 0);
        variable diag_proj_12bit    : unsigned(11 downto 0);
        variable dist_horiz_spoke   : unsigned(11 downto 0);
        variable dist_vert_spoke    : unsigned(11 downto 0);
    begin
        adx_12bit     := resize(pix_adx, 12);
        ady_eff_12bit := resize(pix_ady_eff, 12);
        oct_sum_12bit := adx_12bit + ady_eff_12bit;

        oct_diag_scaled :=
              shift_left(resize(oct_sum_12bit, 19), 7)
            + shift_left(resize(oct_sum_12bit, 19), 5)
            + shift_left(resize(oct_sum_12bit, 19), 4)
            + shift_left(resize(oct_sum_12bit, 19), 2)
            + resize(oct_sum_12bit, 19);
        oct_diag_shifted := shift_right(oct_diag_scaled, OCT_DIAG_WEIGHT_SHIFT);
        diag_proj_12bit  := oct_diag_shifted(11 downto 0);

        if adx_12bit >= diag_proj_12bit then
            dist_horiz_spoke := adx_12bit - diag_proj_12bit;
        else
            dist_horiz_spoke := diag_proj_12bit - adx_12bit;
        end if;

        if ady_eff_12bit >= diag_proj_12bit then
            dist_vert_spoke := ady_eff_12bit - diag_proj_12bit;
        else
            dist_vert_spoke := diag_proj_12bit - ady_eff_12bit;
        end if;

        if dist_horiz_spoke <= dist_vert_spoke then
            spoke_dist <= dist_horiz_spoke;
        else
            spoke_dist <= dist_vert_spoke;
        end if;
    end process;

    -- Spoke is visible when:
    --   (a) angular width check: spoke_dist × taper_factor < oct_dist
    --       → spoke narrows proportionally toward the vanishing point
    --   (b) absolute cap: spoke_dist < SPOKE_MAX_WIDTH_PX (max width at edge)
    --   (c) not inside the dead zone
    on_spoke <= '1'
        when to_integer(spoke_dist) * SPOKE_TAPER_FACTOR < to_integer(oct_dist)
         and to_integer(spoke_dist) < SPOKE_MAX_WIDTH_PX
         and in_dead_zone = '0'
        else '0';

    -- ================================================================
    -- LOG2 ENCODER  (12-bit: [11:8]=octave index, [7:0]=fine position)
    -- ------------------------------------------------------------------
    -- Converts oct_dist → log_depth so that rings appear at equal
    -- visual spacing (log-space = equal angular spacing in 3D).
    -- oct_dist max ≈ 595, so the highest octave needed is 9 (2^9=512).
    -- ================================================================
    process(oct_dist)
    begin
        if    oct_dist(9) = '1' then
            log_depth <= "1001" & oct_dist(8 downto 1);    -- octave 9
        elsif oct_dist(8) = '1' then
            log_depth <= "1000" & oct_dist(7 downto 0);    -- octave 8
        elsif oct_dist(7) = '1' then
            log_depth <= "0111" & oct_dist(6 downto 0) & '0';
        elsif oct_dist(6) = '1' then
            log_depth <= "0110" & oct_dist(5 downto 0) & "00";
        elsif oct_dist(5) = '1' then
            log_depth <= "0101" & oct_dist(4 downto 0) & "000";
        elsif oct_dist(4) = '1' then
            log_depth <= "0100" & oct_dist(3 downto 0) & "0000";
        elsif oct_dist(3) = '1' then
            log_depth <= "0011" & oct_dist(2 downto 0) & "00000";
        elsif oct_dist(2) = '1' then
            log_depth <= "0010" & oct_dist(1 downto 0) & "000000";
        elsif oct_dist(1) = '1' then
            log_depth <= "0001" & oct_dist(0)          & "0000000";
        else
            log_depth <= (others => '0');
        end if;
    end process;

    -- Top 8 bits of log_depth for obstacle depth comparison
    depth_band <= log_depth(11 downto 4);

    -- Subtract scroll×8 so rings animate toward the player each frame.
    -- Each scroll increment shifts all rings 8 log-steps = 1/16 of a ring period.
    ring_phase <= log_depth
                - resize(shift_left(resize(unsigned(scroll), 12), 3), 12);

    -- Ring is visible at the LSB rollover of the ring period
    on_ring <= '1'
        when to_integer(ring_phase(RING_SPACING_LOG2 - 1 downto 0)) < RING_LINE_WIDTH
         and in_dead_zone = '0'
        else '0';

    -- ================================================================
    -- DEPTH BRIGHTNESS
    -- ------------------------------------------------------------------
    -- Maps oct_dist to a 0-15 brightness value.
    -- oct_dist[9:5] gives a coarse depth index (0 at VP, 18 at edge).
    -- Adding BRIGHTNESS_FLOOR prevents the inner rings from going black.
    -- ================================================================
    process(oct_dist)
        variable raw_brightness : unsigned(5 downto 0);
    begin
        raw_brightness := ('0' & oct_dist(9 downto 5)) + BRIGHTNESS_FLOOR;
        if raw_brightness >= 16 then
            brightness <= "1111";
        else
            brightness <= raw_brightness(3 downto 0);
        end if;
    end process;

    -- ================================================================
    -- OBSTACLE DEPTH COMPARISONS
    -- ------------------------------------------------------------------
    -- A pixel is "on obstacle i" when all three are true:
    --   1. obs_active = '1'
    --   2. |depth_band − obs_depth| < OBSTACLE_BAND_WIDTH  (right depth)
    --   3. face_sector = obs_face_sector                   (right face)
    -- ================================================================
    process(depth_band, face_sector,
            obs0_depth_d, obs0_face_d, obs0_active_d,
            obs1_depth_d, obs1_face_d, obs1_active_d,
            obs2_depth_d, obs2_face_d, obs2_active_d,
            obs3_depth_d, obs3_face_d, obs3_active_d)
        variable depth_diff0, depth_diff1,
                 depth_diff2, depth_diff3 : signed(8 downto 0);
    begin
        depth_diff0 := signed('0' & depth_band) - signed('0' & unsigned(obs0_depth_d));
        depth_diff1 := signed('0' & depth_band) - signed('0' & unsigned(obs1_depth_d));
        depth_diff2 := signed('0' & depth_band) - signed('0' & unsigned(obs2_depth_d));
        depth_diff3 := signed('0' & depth_band) - signed('0' & unsigned(obs3_depth_d));

        on_obstacle <= '0';
        if obs0_active_d = '1'
           and depth_diff0 > -OBSTACLE_BAND_WIDTH and depth_diff0 < OBSTACLE_BAND_WIDTH
           and face_sector = obs0_face_d
        then on_obstacle <= '1'; end if;

        if obs1_active_d = '1'
           and depth_diff1 > -OBSTACLE_BAND_WIDTH and depth_diff1 < OBSTACLE_BAND_WIDTH
           and face_sector = obs1_face_d
        then on_obstacle <= '1'; end if;

        if obs2_active_d = '1'
           and depth_diff2 > -OBSTACLE_BAND_WIDTH and depth_diff2 < OBSTACLE_BAND_WIDTH
           and face_sector = obs2_face_d
        then on_obstacle <= '1'; end if;

        if obs3_active_d = '1'
           and depth_diff3 > -OBSTACLE_BAND_WIDTH and depth_diff3 < OBSTACLE_BAND_WIDTH
           and face_sector = obs3_face_d
        then on_obstacle <= '1'; end if;
    end process;

    -- ================================================================
    -- SCORING RING DEPTH COMPARISONS
    -- Scoring rings appear across the full ring (any face sector).
    -- ================================================================
    process(depth_band, ring0_depth_d, ring0_active_d,
                        ring1_depth_d, ring1_active_d)
        variable ring_diff0, ring_diff1 : signed(8 downto 0);
    begin
        ring_diff0 := signed('0' & depth_band) - signed('0' & unsigned(ring0_depth_d));
        ring_diff1 := signed('0' & depth_band) - signed('0' & unsigned(ring1_depth_d));

        on_score_ring <= '0';
        if ring0_active_d = '1'
           and ring_diff0 > -OBSTACLE_BAND_WIDTH and ring_diff0 < OBSTACLE_BAND_WIDTH
        then on_score_ring <= '1'; end if;

        if ring1_active_d = '1'
           and ring_diff1 > -OBSTACLE_BAND_WIDTH and ring_diff1 < OBSTACLE_BAND_WIDTH
        then on_score_ring <= '1'; end if;
    end process;

    -- ================================================================
    -- STAGE 0  —  Coordinate rotation + ship sprite hit detection
    -- ------------------------------------------------------------------
    -- Rotates each screen pixel (hpos, vpos) into the tunnel's frame
    -- using the cos/sin values from trig_rom.
    --   dx_rotated =  (dx × cos_t + dy × sin_t) / 256
    --   dy_rotated = (-dx × sin_t + dy × cos_t) / 256
    -- Division by 256 normalises cos/sin (range ±255 ≈ ±1.0).
    -- Uses signed(20) intermediate to prevent 20-bit product overflow.
    --
    -- Ship hit: Manhattan distance |Δx|+|Δy| < SHIP_DIAMOND_SIZE.
    -- Checked in screen space (before rotation) so the sprite stays
    -- at its exact pixel position regardless of tunnel angle.
    --
    -- Obstacle/ring inputs pipelined 1 stage to stay in sync.
    -- ================================================================
    process(clk_50)
        variable dx_centre, dy_centre         : signed(10 downto 0);
        variable dx_cos, dx_sin               : signed(19 downto 0);
        variable dy_cos, dy_sin               : signed(19 downto 0);
        variable rotated_x, rotated_y         : signed(20 downto 0);
        variable ship_dx, ship_dy             : signed(10 downto 0);
        variable ship_dx_abs, ship_dy_abs     : signed(10 downto 0);
        variable ship_dist                    : unsigned(10 downto 0);
    begin
        if rising_edge(clk_50) then

            -- Centre-offset coordinates  (VP at 400, 300)
            dx_centre := signed('0' & hpos) - to_signed(400, 11);
            dy_centre := signed('0' & vpos) - to_signed(300, 11);

            -- Rotation matrix
            dx_cos := dx_centre * cos_t;
            dx_sin := dx_centre * sin_t;
            dy_cos := dy_centre * cos_t;
            dy_sin := dy_centre * sin_t;

            -- Sum with 21-bit intermediate (prevents overflow at max ±400×255)
            rotated_x :=  resize(dx_cos, 21) + resize(dy_sin, 21);
            rotated_y := -resize(dx_sin, 21) + resize(dy_cos, 21);

            -- Divide by 256 and register
            dx_rotated <= resize(shift_right(rotated_x, 8), 12);
            dy_rotated <= resize(shift_right(rotated_y, 8), 12);

            -- Video blanking
            video_active <= video_on;

            -- Ship diamond hit (screen space, before rotation)
            ship_dx     := signed('0' & hpos) - signed('0' & std_logic_vector(ship_x));
            ship_dy     := signed('0' & vpos) - signed('0' & std_logic_vector(ship_y));
            ship_dx_abs := abs(ship_dx);   -- intermediate variable for safe slicing
            ship_dy_abs := abs(ship_dy);
            ship_dist   := ('0' & unsigned(ship_dx_abs(9 downto 0)))
                         + ('0' & unsigned(ship_dy_abs(9 downto 0)));
            if ship_dist < SHIP_DIAMOND_SIZE then
                ship_hit <= '1';
            else
                ship_hit <= '0';
            end if;

            -- Pipeline obstacle/ring signals (1 cycle to align with rotated coords)
            obs0_depth_d  <= obs0_depth;
            obs0_face_d   <= obs0_face_sector;
            obs0_active_d <= obs0_active;
            obs1_depth_d  <= obs1_depth;
            obs1_face_d   <= obs1_face_sector;
            obs1_active_d <= obs1_active;
            obs2_depth_d  <= obs2_depth;
            obs2_face_d   <= obs2_face_sector;
            obs2_active_d <= obs2_active;
            obs3_depth_d  <= obs3_depth;
            obs3_face_d   <= obs3_face_sector;
            obs3_active_d <= obs3_active;
            ring0_depth_d  <= ring0_depth;
            ring0_active_d <= ring0_active;
            ring1_depth_d  <= ring1_depth;
            ring1_active_d <= ring1_active;

        end if;
    end process;

    -- ================================================================
    -- STAGE 1  —  Colour priority mux (registered output)
    -- ------------------------------------------------------------------
    -- All combinational signals are stable (from Stage-0 registers).
    -- Last assignment wins — higher priority items are written later.
    --
    -- Priority order (1 = lowest, 8 = highest):
    --   1. Dark background       (default, most pixels)
    --   2. Tunnel ring or spoke  (depth-shaded palette colour)
    --   3. Dead zone             (black hole at vanishing point)
    --   4. Scoring ring          (gold)
    --   5. Obstacle block        (orange-red)
    --   6. Ship sprite           (yellow, only during PLAYING)
    --   7. Game-over overlay     (solid red, entire visible frame)
    --   8. Blanking              (black outside active video area)
    -- ================================================================
    process(clk_50)
        -- Palette interpolation
        variable hue_pair            : integer range 0 to 3;
        variable hue_blend           : integer range 0 to 15;
        variable col_a_r, col_a_g, col_a_b : integer range 0 to 15;
        variable col_b_r, col_b_g, col_b_b : integer range 0 to 15;
        variable pal_red, pal_grn, pal_blu : unsigned(3 downto 0);
        -- Depth-shaded colour (4-bit × 4-bit = 8-bit; take top nibble)
        variable shaded_r, shaded_g, shaded_b : unsigned(7 downto 0);
        -- Output colour
        variable out_r, out_g, out_b : std_logic_vector(3 downto 0);
    begin
        if rising_edge(clk_50) then

            -- ── Interpolate palette colour from hue_cnt ────────────
            hue_pair  := to_integer(hue_cnt(9 downto 8));  -- which pair (0-3)
            hue_blend := to_integer(hue_cnt(7 downto 4));  -- blend step (0-15)
            col_a_r := KF_RED(hue_pair);       col_b_r := KF_RED(hue_pair + 1);
            col_a_g := KF_GREEN(hue_pair);     col_b_g := KF_GREEN(hue_pair + 1);
            col_a_b := KF_BLUE(hue_pair);      col_b_b := KF_BLUE(hue_pair + 1);
            pal_red := to_unsigned(col_a_r + ((col_b_r - col_a_r) * hue_blend) / 16, 4);
            pal_grn := to_unsigned(col_a_g + ((col_b_g - col_a_g) * hue_blend) / 16, 4);
            pal_blu := to_unsigned(col_a_b + ((col_b_b - col_a_b) * hue_blend) / 16, 4);

            -- Apply depth brightness (multiply then take top 4 bits)
            shaded_r := pal_red * brightness;
            shaded_g := pal_grn * brightness;
            shaded_b := pal_blu * brightness;

            -- ── 1. Default: near-black background ─────────────────
            out_r := "0001"; out_g := "0000"; out_b := "0001";

            -- ── 2. Tunnel ring or spoke ────────────────────────────
            if on_ring = '1' or on_spoke = '1' then
                out_r := std_logic_vector(shaded_r(7 downto 4));
                out_g := std_logic_vector(shaded_g(7 downto 4));
                out_b := std_logic_vector(shaded_b(7 downto 4));
            end if;

            -- ── 3. Dead zone: black hole at vanishing point ────────
            if in_dead_zone = '1' then
                out_r := "0000"; out_g := "0000"; out_b := "0000";
            end if;

            -- ── 4. Scoring ring (gold) ─────────────────────────────
            if on_score_ring = '1' then
                out_r := std_logic_vector(to_unsigned(SCORE_RING_RED_VAL,   4));
                out_g := std_logic_vector(to_unsigned(SCORE_RING_GREEN_VAL, 4));
                out_b := std_logic_vector(to_unsigned(SCORE_RING_BLUE_VAL,  4));
            end if;

            -- ── 5. Obstacle block (orange-red) ─────────────────────
            if on_obstacle = '1' then
                out_r := std_logic_vector(to_unsigned(OBS_RED_VAL,   4));
                out_g := std_logic_vector(to_unsigned(OBS_GREEN_VAL, 4));
                out_b := std_logic_vector(to_unsigned(OBS_BLUE_VAL,  4));
            end if;

            -- ── 6. Ship sprite (yellow, PLAYING state only) ────────
            if ship_hit = '1' and game_state = "01" then
                out_r := std_logic_vector(to_unsigned(SHIP_RED_VAL,   4));
                out_g := std_logic_vector(to_unsigned(SHIP_GREEN_VAL, 4));
                out_b := std_logic_vector(to_unsigned(SHIP_BLUE_VAL,  4));
            end if;

            -- ── 7. Game-over: solid red flash ─────────────────────
            if game_state = "10" and video_active = '1' then
                out_r := "1111"; out_g := "0000"; out_b := "0000";
            end if;

            -- ── 8. Blanking: black outside active video ────────────
            if video_active = '0' then
                out_r := "0000"; out_g := "0000"; out_b := "0000";
            end if;

            red   <= out_r;
            green <= out_g;
            blue  <= out_b;

        end if;
    end process;

end rtl;
