# ── Quartus build artefacts ──────────────────────────────────────────────────

# Internal compiler databases
db/
incremental_db/
greybox_tmp/

# Compiled output (bitstreams, programming files, reports)
output_files/

# Generated simulation netlists
simulation/

# ── Quartus generated files ───────────────────────────────────────────────────

# Automatic source backups
*.bak
# Workspace window layout (personal)
*.qws
# Chain/programmer setup (board-specific)
*.cdf
# Timing / fitter reports
*.rpt
*.summary
# Suppressed messages
*.smsg
# Pin report
*.pin
*.done
# JTAG debug info
*.jdi
# SignalTap II
*.stp
*.sld
# Quartus database snapshot
*.qdb
# Resource constraint file
*.rcf
# Generated XML / CSV / text reports
*.xml
*.csv
*.txt
